FROM kalilinux/kali-rolling:latest

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      iproute2 \
      iputils-ping \
      netcat-openbsd \
      openssh-client \
      openssh-server \
      curl \
      ca-certificates && \
    mkdir -p /run/sshd /var/run/sshd && \
    rm -rf /var/lib/apt/lists/*

